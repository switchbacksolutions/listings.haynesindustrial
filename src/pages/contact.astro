---
/**
 * src/pages/contact.astro — Contact page
 */

import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact Us"
  description="Contact Haynes Industrial about available equipment and salvage materials. Serving Northern California. Email alec@haynesindustrial.com."
>
  <!-- Page header -->
  <div class="bg-brand-700 text-white">
    <div class="section-container py-12">
      <p class="font-heading text-xs font-bold uppercase tracking-widest text-gold-400 mb-2">
        Get in Touch
      </p>
      <h1 class="text-3xl font-bold text-white">Contact Us</h1>
      <p class="mt-2 text-brand-200 text-sm max-w-lg">
        No online checkout — all transactions handled directly. Reach out with questions,
        custom requests, or to make an offer on any listed item.
      </p>
    </div>
  </div>

  <div class="section-container py-16">
    <div class="grid gap-12 lg:grid-cols-2">

      <!-- Contact info -->
      <div>
        <h2 class="text-xl font-bold text-gray-900 mb-6">How to Reach Us</h2>

        <div class="space-y-6">
          <!-- Email -->
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-10 h-10 rounded-sm bg-brand-100 flex items-center justify-center">
              <svg class="h-5 w-5 text-brand-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
              </svg>
            </div>
            <div>
              <p class="font-heading text-sm font-bold text-gray-900">Email</p>
              <a
                href="mailto:alec@haynesindustrial.com"
                class="text-brand-600 no-underline hover:underline text-sm mt-0.5 block"
              >
                alec@haynesindustrial.com
              </a>
              <p class="text-xs text-gray-400 mt-1">Best way to reach us — include item name or SKU.</p>
            </div>
          </div>

          <!-- Location -->
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-10 h-10 rounded-sm bg-brand-100 flex items-center justify-center">
              <svg class="h-5 w-5 text-brand-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
              </svg>
            </div>
            <div>
              <p class="font-heading text-sm font-bold text-gray-900">Location</p>
              <p class="text-sm text-gray-600 mt-0.5">Northern California</p>
              <p class="text-xs text-gray-400 mt-1">Pickup available at our yard. Contact for address.</p>
            </div>
          </div>

          <!-- Instagram -->
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-10 h-10 rounded-sm bg-brand-100 flex items-center justify-center">
              <svg class="h-5 w-5 text-brand-600" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" />
              </svg>
            </div>
            <div>
              <p class="font-heading text-sm font-bold text-gray-900">Instagram</p>
              <a
                href="https://www.instagram.com/haynesindustrial"
                class="text-brand-600 no-underline hover:underline text-sm mt-0.5 block"
                target="_blank"
                rel="noopener noreferrer"
              >
                @haynesindustrial
              </a>
              <p class="text-xs text-gray-400 mt-1">Follow us for new inventory and project updates.</p>
            </div>
          </div>
        </div>

        <!-- Main site link -->
        <div class="mt-10 rounded-sm border border-brand-200 bg-brand-50 p-5">
          <p class="font-heading text-sm font-bold text-brand-800 mb-1">Need demolition or recycling services?</p>
          <p class="text-xs text-brand-600 mb-3">
            This site is for materials and equipment sales only. For demolition, recycling,
            and waste management services, visit our main website.
          </p>
          <a
            href="https://www.haynesindustrial.com"
            class="text-sm font-semibold text-brand-700 no-underline hover:underline"
            target="_blank"
            rel="noopener noreferrer"
          >
            Visit haynesindustrial.com →
          </a>
        </div>
      </div>

      <!-- Quick inquiry panel -->
      <div>
        <h2 class="text-xl font-bold text-gray-900 mb-6">Quick Inquiry</h2>
        <div class="rounded-sm border-2 border-brand-600 p-6">
          <p class="text-sm text-gray-600 mb-6 leading-relaxed">
            The fastest way to inquire is email. Click the button below to open a pre-filled
            email, or write to us directly at{' '}
            <a href="mailto:alec@haynesindustrial.com" class="text-brand-600 no-underline hover:underline font-medium">
              alec@haynesindustrial.com
            </a>.
          </p>

          <a
            href="mailto:alec@haynesindustrial.com?subject=General%20Inquiry&body=Hi%20Alec%2C%0A%0AI%27m%20interested%20in%20learning%20more%20about%20your%20available%20inventory.%0A%0APlease%20let%20me%20know%20what%20you%20currently%20have%20available%20in%3A%0A%0AThank%20you%2C%0A"
            class="btn-primary w-full justify-center"
          >
            Email Us Now
          </a>

          <p class="mt-6 text-xs text-gray-400 text-center">
            No online payment or checkout. All sales arranged directly.
          </p>

          <hr class="my-6 border-gray-200" />

          <div>
            <p class="font-heading text-xs font-bold uppercase tracking-widest text-gray-400 mb-3">When you email, include:</p>
            <ul class="space-y-2 list-none m-0 p-0">
              {[
                'Item name or SKU from the listing',
                'Your intended use / project details',
                'Quantity needed (if applicable)',
                'Your location (for freight estimates)',
              ].map((tip) => (
                <li class="flex items-start gap-2 text-sm text-gray-600">
                  <svg class="h-4 w-4 text-gold-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm3.857-9.809a.75.75 0 0 0-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 1 0-1.06 1.061l2.5 2.5a.75.75 0 0 0 1.137-.089l4-5.5Z" clip-rule="evenodd" />
                  </svg>
                  {tip}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
