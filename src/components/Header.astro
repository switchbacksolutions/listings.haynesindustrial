---
/**
 * Header.astro
 * Site header matching Haynes Industrial branding.
 * Steel blue background, white navigation, gold CTA.
 */

const NAV_LINKS = [
  { href: '/', label: 'Listings' },
  { href: '/contact', label: 'Contact' },
];

const pathname = new URL(Astro.request.url).pathname;

function isActive(href: string): boolean {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<!-- Top bar: back-link to main site -->
<div class="bg-brand-900 py-1.5">
  <div class="section-container flex justify-end">
    <a
      href="https://www.haynesindustrial.com"
      class="text-xs text-brand-200 no-underline hover:text-white transition-colors"
      target="_blank"
      rel="noopener noreferrer"
    >
      ← Back to Haynes Industrial
    </a>
  </div>
</div>

<!-- Main header -->
<header class="sticky top-0 z-50 bg-brand-700 shadow-md">
  <div class="section-container flex items-center justify-between py-4">

    <!-- Logo / site name -->
    <a href="/" class="no-underline flex flex-col leading-tight">
      <span class="font-heading text-xl font-bold text-white tracking-wide uppercase">
        Haynes Industrial
      </span>
      <span class="text-xs font-medium text-brand-200 uppercase tracking-widest">
        Equipment &amp; Materials
      </span>
    </a>

    <!-- Desktop navigation -->
    <nav aria-label="Main navigation" class="hidden sm:block">
      <ul class="flex items-center gap-8 list-none m-0 p-0">
        {NAV_LINKS.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class:list={[
                'font-heading text-sm font-semibold uppercase tracking-wide no-underline transition-colors',
                isActive(href)
                  ? 'text-gold-400'
                  : 'text-white hover:text-gold-300',
              ]}
              aria-current={isActive(href) ? 'page' : undefined}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- CTA -->
    <a
      href="mailto:jon@haynesindustrial.com"
      class="btn-primary hidden sm:inline-flex"
    >
      Request a Quote
    </a>

    <!-- Mobile menu toggle (simple, no JS framework) -->
    <button
      id="mobile-menu-toggle"
      type="button"
      aria-label="Open navigation menu"
      class="sm:hidden rounded p-2 text-white hover:bg-brand-600 transition-colors"
    >
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden sm:hidden bg-brand-800 border-t border-brand-600">
    <nav aria-label="Mobile navigation">
      <ul class="flex flex-col list-none m-0 p-0">
        {NAV_LINKS.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class:list={[
                'block px-6 py-3 font-heading text-sm font-semibold uppercase tracking-wide no-underline border-b border-brand-700 transition-colors',
                isActive(href)
                  ? 'text-gold-400'
                  : 'text-white hover:text-gold-300 hover:bg-brand-700',
              ]}
            >
              {label}
            </a>
          </li>
        ))}
        <li class="p-4">
          <a href="mailto:jon@haynesindustrial.com" class="btn-primary w-full justify-center">
            Request a Quote
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
