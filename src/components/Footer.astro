---
/**
 * Footer.astro
 * Site-wide footer matching Haynes Industrial branding.
 */

const year = new Date().getFullYear();
---

<footer class="bg-brand-900 text-white">
  <div class="section-container py-12">
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-3">

      <!-- Brand column -->
      <div>
        <p class="font-heading text-lg font-bold uppercase tracking-wide text-white">
          Haynes Industrial
        </p>
        <p class="mt-1 text-xs font-medium uppercase tracking-widest text-brand-300">
          Equipment &amp; Materials
        </p>
        <p class="mt-4 text-sm text-brand-200 leading-relaxed">
          Demolition, recycling, and universal waste management services across
          Northern California.
        </p>
        <a
          href="https://www.haynesindustrial.com"
          class="mt-4 inline-block text-sm text-gold-400 no-underline hover:underline"
          target="_blank"
          rel="noopener noreferrer"
        >
          Visit our main site →
        </a>
      </div>

      <!-- Quick links -->
      <div>
        <p class="font-heading text-xs font-bold uppercase tracking-widest text-brand-300 mb-4">
          Quick Links
        </p>
        <ul class="space-y-2 list-none m-0 p-0">
          {[
            { href: '/', label: 'All Listings' },
            { href: '/contact', label: 'Contact Us' },
            { href: 'https://www.haynesindustrial.com', label: 'Main Website', external: true },
          ].map(({ href, label, external }) => (
            <li>
              <a
                href={href}
                class="text-sm text-brand-200 no-underline hover:text-white transition-colors"
                target={external ? '_blank' : undefined}
                rel={external ? 'noopener noreferrer' : undefined}
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <p class="font-heading text-xs font-bold uppercase tracking-widest text-brand-300 mb-4">
          Get in Touch
        </p>
        <p class="text-sm text-brand-200 mb-3">
          Interested in an item or have a custom request? Reach out directly.
        </p>
        <a
          href="mailto:jon@haynesindustrial.com"
          class="text-sm text-gold-400 no-underline hover:underline break-all"
        >
          jon@haynesindustrial.com
        </a>
        <div class="mt-4">
          <p class="text-xs text-brand-400 uppercase tracking-wide mb-2">Follow us</p>
          <a
            href="https://www.instagram.com/haynesindustrial"
            class="text-sm text-brand-200 no-underline hover:text-white transition-colors"
            target="_blank"
            rel="noopener noreferrer"
          >
            @haynesindustrial
          </a>
        </div>
      </div>
    </div>

    <div class="mt-10 border-t border-brand-700 pt-6 text-center">
      <p class="text-xs text-brand-400">
        &copy; {year} Haynes Industrial. All rights reserved. Northern California.
      </p>
      <p class="mt-1 text-xs text-brand-600">
        Site by <a
          href="https://www.switchbacksolutions.net/"
          class="hover:text-brand-400 transition-colors no-underline"
          target="_blank"
          rel="noopener noreferrer"
        >Switchback Solutions</a>
      </p>
    </div>
  </div>
</footer>
